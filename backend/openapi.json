  "info": {
    "title": "Willy API",
    "description": "",
    "version": "0.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SessionUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "OPERATOR",
              "VIEWER"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "role"
        ]
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/SessionUserDto"
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user"
        ]
      },
      "OkResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "ok"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "OPERATOR",
              "VIEWER"
            ]
          }
        },
        "required": [
          "userId",
          "email",
          "role"
        ]
      },
      "CreateDeploymentDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,40}$",
            "example": "my-app"
          },
          "type": {
            "type": "string",
            "enum": [
              "WEB",
              "WORKER",
              "CRON"
            ]
          },
          "gitUrl": {
            "type": "string",
            "example": "https://github.com/owner/repo.git"
          },
          "gitRef": {
            "type": "string",
            "example": "main"
          },
          "buildStrategy": {
            "type": "string",
            "enum": [
              "NIXPACKS",
              "DOCKERFILE",
              "COMPOSE"
            ]
          },
          "dockerfilePath": {
            "type": "string"
          },
          "composeFilePath": {
            "type": "string",
            "example": "docker-compose.yml"
          },
          "composeWebService": {
            "type": "string",
            "description": "Compose service to route + monitor."
          },
          "webServicePort": {
            "type": "number",
            "minimum": 1,
            "maximum": 65535
          },
          "healthCheckPath": {
            "type": "string",
            "example": "/"
          },
          "runCommand": {
            "type": "string"
          },
          "cronExpr": {
            "type": "string",
            "example": "0 3 * * *"
          },
          "domain": {
            "type": "string",
            "example": "app.example.com"
          },
          "gitToken": {
            "type": "string",
            "description": "Personal access token for a private repo (encrypted at rest)."
          },
          "memoryLimitMb": {
            "type": "number",
            "minimum": 16
          }
        },
        "required": [
          "name",
          "type",
          "gitUrl"
        ]
      },
      "DeploymentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "WEB",
              "WORKER",
              "CRON"
            ]
          },
          "gitUrl": {
            "type": "string"
          },
          "gitRef": {
            "type": "string"
          },
