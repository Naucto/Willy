{
  "name": "@willy/backend",
  "version": "0.0.0",
  "private": true,
  "description": "Willy control plane (NestJS + Drizzle)",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src && prettier --check \"src/**/*.ts\" \"*.ts\" \"*.mjs\"",
    "lint:fix": "eslint src --fix && prettier --write \"src/**/*.ts\" \"*.ts\" \"*.mjs\"",
    "format": "prettier --write \"src/**/*.ts\" \"*.ts\" \"*.mjs\"",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "generate:openapi": "tsx src/openapi.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.4.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "dockerode": "^5.0.0",
    "drizzle-orm": "^0.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^25.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.0"
  }
}
