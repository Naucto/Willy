{
  "name": "@willy/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Willy control panel (React + Vite + MUI).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "generate:api": "npx -y openapi-typescript@^7 ../backend/openapi.json -o src/api/schema.d.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/x-charts": "^9.6.0",
    "@mui/x-data-grid": "^9.5.0",
    "@mui/x-date-pickers": "^9.6.0",
    "@mui/x-tree-view": "^9.6.0",
    "@tanstack/react-query": "^5.101.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "anser": "^2.3.5",
    "cronstrue": "^3.21.0",
    "dayjs": "^1.11.21",
    "monaco-editor": "^0.55.1",
    "notistack": "^3.0.2",
    "openapi-fetch": "^0.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.79.0",
    "react-router-dom": "^7.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
