# Willy configuration. Copy to .env and fill in. NEVER commit the real .env.
# In production this file is generated (mode 600) by scripts/provision.sh.

# --- Domain / panel ---
# Base domain = the panel's home + the default zone offered in the new-deployment wizard.
# Apps may use any other OVH-managed zone.
BASE_DOMAIN=willy.localhost
PANEL_HOST=willy.localhost

# --- ACME / TLS (production; ignored by the local mkcert override) ---
ACME_EMAIL=ops@example.com
# Start on staging, flip to prod once issuance works:
#   staging: https://acme-staging-v02.api.letsencrypt.org/directory
#   prod:    https://acme-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# --- OVH API (DNS-01 certs + in-panel DNS management). ---
# Token rights for full in-panel DNS (incl. zone auto-discovery):
#   GET /domain/zone              (list every zone)
#   GET/POST/PUT/DELETE /domain/zone/*   (read + edit records, refresh)
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
OVH_PROPAGATION_TIMEOUT=120

# DNS backend: "ovh" | "local". Unset = auto (OVH when creds above are set, else a local
# in-memory provider for `make dev` — no OVH account or public DNS needed).
DNS_PROVIDER=

# --- Secrets (generate with: openssl rand -hex 32 / -base64 32) ---
# Master key encrypts all stored app secrets — losing it loses every secret.
WILLY_MASTER_KEY=
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Willy metadata database (Postgres) ---
POSTGRES_USER=willy
POSTGRES_PASSWORD=
POSTGRES_DB=willy
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://willy:@postgres:5432/willy

# --- Docker access (via least-privilege socket proxy) ---
DOCKER_PROXY_HOST=docker-socket-proxy
DOCKER_PROXY_PORT=2375

# --- Control-plane runtime ---
BUILD_CONCURRENCY=2
RELEASE_KEEP_N=3
HEALTHCHECK_TIMEOUT=120
BUILDS_DIR=/var/willy/builds
BACKUPS_DIR=/var/willy/backups

# --- Admin bootstrap (seeded on first boot; password auto-generated if blank) ---
WILLY_ADMIN_EMAIL=admin@willy.localhost
WILLY_ADMIN_PASSWORD=
