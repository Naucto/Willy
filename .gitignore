# Dependencies
node_modules/

# Build output (both workspaces emit to dist/; no bare build/ — it would shadow backend/src/build/)
dist/
*.tsbuildinfo

# Test / coverage
coverage/
test-results/
playwright-report/
.vitest/

# Env & secrets — never commit real values
.env
.env.*
!.env.example

# Local TLS (mkcert) + ACME cert store + generated dashboard auth
routing/certs/
routing/letsencrypt/
routing/auth/

# Empty mountpoint Docker creates for the local-only TLS file (nested bind mount)
routing/dynamic/tls.local.yml

# Local build workspaces / backup artifacts (host runtime dirs)
/var/willy/

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
